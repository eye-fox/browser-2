def _rand_fp(w=0, h=0, tz=None, locale=None):
    fp = {}
    if w and h:
        fp['w'], fp['h'] = w, h
    else:
        fp['w'], fp['h'] = random.choice(_COMMON_SIZES)
    fp['sat'] = random.randint(20, 40)
    fp['sal'] = random.randint(0, 5)
    fp['sah'] = fp['h'] - fp['sat'] - random.randint(10, 30)
    fp['saw'] = fp['w'] - fp['sal'] * 2
    fp['hc'] = random.choice([4, 8, 12, 16])
    fp['dm'] = random.choice([4, 8])
    fp['mtp'] = random.choice([0, 1])
    fp['cd'] = random.choice([24, 30, 48])
    fp['ect'] = random.choice(['4g', '3g', 'wifi'])
    fp['dl'] = random.randint(5, 50)
    fp['dlmax'] = random.randint(50, 200)
    fp['rtt'] = random.randint(20, 150)
    fp['gpu_vendor'], fp['gpu_renderer'] = random.choice(_WEBGL_VENDORS)
    fp['tz'] = tz or random.choice([
        'America/New_York','America/Chicago','America/Denver','America/Los_Angeles',
        'Europe/London','Europe/Berlin','Europe/Paris','Asia/Tokyo',
        'Asia/Shanghai','Asia/Jakarta','Asia/Singapore','Australia/Sydney'
    ])
    fp['locale'] = locale or random.choice([
        'en-US','en-GB','id-ID','de-DE','fr-FR','ja-JP','zh-CN','en-AU','ko-KR'
    ])
    fp['platform'] = 'Linux x86_64'
    fp['arch'] = 'x86'
