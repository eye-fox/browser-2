    wtp = wa.add_parser("text"); wtp.add_argument("value"); wtp.add_argument("--timeout", type=int, default=15)
    wnp = wa.add_parser("navigation"); wnp.add_argument("--timeout", type=int, default=10)
    wip = wa.add_parser("networkidle"); wip.add_argument("--timeout", type=int, default=15); wip.add_argument("--quiet", type=float, default=0.5)
    wep = wa.add_parser("element"); wep.add_argument("value"); wep.add_argument("--timeout", type=int, default=15)
