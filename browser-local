    for _ in range(timeout * 2):
        r = js_eval(ws, ses, "document.readyState")
        if r == "complete":
            return js_eval(ws, ses, "JSON.stringify({url:location.href,title:document.title,ready:document.readyState})")
        time.sleep(0.5)
    return json.dumps({"timeout":True,"readyState":r})

