def _wait_cf_clearance(ws, ses, timeout=30):
    for _ in range(timeout * 2):
        try:
            cookies = cdp(ws, "Network.getAllCookies", session_id=ses)
            for c in cookies.get("cookies", []):
                if c.get("name") == "cf_clearance":
                    return True
        except: pass
        t = js_eval(ws, ses, "document.title")
        if t and "Just a moment" not in str(t):
            return True
        time.sleep(0.5)
    return False

def _wait_network_idle(ws, ses, timeout=15, quiet=0.5):
    t0 = time.time()
    while time.time() - t0 < timeout:
        pending = js_eval(ws, ses, "window.__bl_net||0")
        ready = js_eval(ws, ses, "document.readyState")
        p = pending if isinstance(pending,(int,float)) else 1
        if p == 0 and ready == "complete":
            time.sleep(quiet)
            p2 = js_eval(ws, ses, "window.__bl_net||0")
            if isinstance(p2,(int,float)) and p2 == 0:
                return js_eval(ws, ses, "JSON.stringify({url:location.href,title:document.title,ready:document.readyState,idle:true})")
        time.sleep(0.3)
    return json.dumps({"timeout":True,"pending":p,"readyState":ready})

def _wait_element(ws, ses, idx, timeout=15):
    for _ in range(timeout * 2):
        els = json.loads(get_elements(ws, ses))
        if isinstance(els, list) and idx < len(els):
            return json.dumps({"found":idx,"tag":els[idx]["tag"],"text":els[idx]["text"][:30],"id":els[idx]["id"]})
        time.sleep(0.5)
    return json.dumps({"timeout":True,"index":idx})

def _intercept(ws, ses, action, args):
    if action == "start":
        pat = getattr(args, 'pattern', '') or '.*'
        js_eval(ws, ses, f"window.__bl_intercept_pattern={json.dumps(pat)}")
        r = js_eval(ws, ses, INTERCEPT_JS)
        if isinstance(r, dict) and r.get("error"):
            return json.dumps({"error":r["error"]})
        return json.dumps({"intercept":"started","pattern":pat})
    elif action == "stop":
        r = js_eval(ws, ses, """(function(){
            if(!window.__bl_intercept_active) return {intercept:'already_stopped'};
            window.__bl_intercept_active=false;
            var _f=window.__bl_orig_fetch||window.fetch;
            var released=0;
            var q=window.__bl_intercepted||[];
            for(var i=0;i<q.length;i++){
                if(window.__bl_intercept_paused.has(q[i].id)){
                    window.__bl_intercept_paused.delete(q[i].id);
                    if(q[i].type==='fetch'){q[i]._resolve(_f(q[i].url,{method:q[i].method,headers:q[i].headers,body:q[i].body}));}
                    else if(q[i].type==='xhr'&&q[i]._send){q[i]._send();}
                    released++;
                }
            }
            window.__bl_intercepted=[];
            return {intercept:'stopped',released:released};
        })()""")
        return r if isinstance(r,str) else json.dumps(r)
    elif action == "list":
        r = js_eval(ws, ses, """JSON.stringify((window.__bl_intercepted||[]).filter(function(r){return window.__bl_intercept_paused.has(r.id)}).map(function(r,i){return{index:i,id:r.id,url:r.url,method:r.method,type:r.type,headers:r.headers,body:r.body?String(r.body).slice(0,500):null}}))""")
        return r
    elif action == "continue":
        idx = int(args.idx)
        r = js_eval(ws, ses, f"""JSON.stringify((function(){{
            var q=window.__bl_intercepted||[];
            var found=0;
            for(var i=0;i<q.length;i++){{
                if(window.__bl_intercept_paused.has(q[i].id)){{
                    if(found===parseInt({json.dumps(idx)})){{
                        window.__bl_intercept_paused.delete(q[i].id);
                        if(q[i].type==='fetch'){{var _f=window.__bl_orig_fetch||window.fetch;q[i]._resolve(_f(q[i].url,{{method:q[i].method,headers:q[i].headers,body:q[i].body}}));}}
                        else if(q[i].type==='xhr'&&q[i]._send){{q[i]._send();}}
                        return {{intercept:'continued',id:q[i].id,url:q[i].url}};
                    }}
                    found++;
                }}
            }}
            return {{error:'index not found'}};
        }})())""")
        return r if isinstance(r,str) else json.dumps(r)
    elif action == "modify":
        idx = int(getattr(args,'idx',0))
        body = getattr(args,'body',None)
        method = getattr(args,'method',None)
        hdrs = getattr(args,'header',None) or []
        hdr_obj = {}
        for h in hdrs:
            if ':' in h: k,v = h.split(':',1); hdr_obj[k.strip()] = v.strip()
        js = """(function(){
            var q=window.__bl_intercepted||[];
            var found=0;
            for(var i=0;i<q.length;i++){
                if(window.__bl_intercept_paused.has(q[i].id)){
                    if(found=="""+str(idx)+"""){
                        """+(f"q[i].body={json.dumps(body)};" if body else "")+"""
                        """+(f"q[i].method={json.dumps(method)};" if method else "")+"""
                        """+(f"var h={json.dumps(hdr_obj)};for(var k in h)q[i].headers[k]=h[k];" if hdr_obj else "")+"""
                        return JSON.stringify({intercept:'modified',id:q[i].id,url:q[i].url,method:q[i].method,body:String(q[i].body||'').slice(0,200)});
                    }
                    found++;
                }
            }
            return JSON.stringify({error:'index not found'});
        })()"""
        r = js_eval(ws, ses, js)
        return r if isinstance(r,str) else json.dumps(r)
    return json.dumps({"error":"unknown action"})

def _type_text(ws, ses, text, idx=None):
    global HUMAN_MODE
    if idx is not None:
        els = json.loads(get_elements(ws, ses))
        if idx >= len(els): return {"error":f"index {idx} out of range"}
        e = els[idx]
        x = e["rect"]["x"] + e["rect"]["w"]//2
        y = e["rect"]["y"] + e["rect"]["h"]//2
        _click_coords(ws, ses, x, y)
        if HUMAN_MODE:
            time.sleep(0.2)
    if not HUMAN_MODE:
        escaped = json.dumps(text)
        js_eval(ws, ses, f"try{{const el=document.activeElement;if(el&&typeof el.value!=='undefined'){{el.value={escaped};el.dispatchEvent(new Event('input',{{bubbles:true}}));el.dispatchEvent(new Event('change',{{bubbles:true}}))}}}}catch(e){{}}")
        return {"typed":text}
    js_eval(ws, ses, "try{const el=document.activeElement;if(el&&el.tagName!=='BODY'&&typeof el.value!=='undefined'){el.value='';el.focus();el.dispatchEvent(new Event('focus',{bubbles:true}))}}catch(e){}")
    time.sleep(0.1)
    for char in text:
        if char == '\n':
            cdp(ws, "Input.dispatchKeyEvent",{"type":"rawKeyDown","key":"Enter","windowsVirtualKeyCode":13},session_id=ses)
            cdp(ws, "Input.dispatchKeyEvent",{"type":"keyUp","key":"Enter","windowsVirtualKeyCode":13},session_id=ses)
        else:
            cdp(ws, "Input.dispatchKeyEvent",{"type":"keyDown","key":char,"windowsVirtualKeyCode":ord(char)},session_id=ses)
            cdp(ws, "Input.dispatchKeyEvent",{"type":"char","key":char,"windowsVirtualKeyCode":ord(char),"text":char,"unmodifiedText":char},session_id=ses)
            cdp(ws, "Input.dispatchKeyEvent",{"type":"keyUp","key":char,"windowsVirtualKeyCode":ord(char)},session_id=ses)
        time.sleep(random.uniform(0.03, 0.08))
    return {"typed":text}

def _scroll(ws, ses, direction="down", amount=300):
    sign = 1 if direction == "down" else -1
    js_eval(ws, ses, f"window.scrollBy(0,{sign*amount})")
    return {"scrolled":direction,"amount":amount}

def cmd_start(args):
    if os.path.exists(DATA_DIR):
        for _ in range(10):
            try: shutil.rmtree(DATA_DIR); break
            except: time.sleep(0.5)
    os.makedirs(DATA_DIR, exist_ok=True)
    port = args.port or 0
    w = args.width or 0
    h = args.height or 0
    if not w or not h:
        sz = random.choice(_COMMON_SIZES)
        if not w: w = sz[0]
        if not h: h = sz[1]
    locale = args.locale or 'en-US'
    ua = f'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/{BVER}.0.0.0 Safari/537.36'
    cmd = [
        BROWSER, f"--remote-debugging-port={port}",
        "--headless=new" if not args.headed else "",
        "--no-sandbox",
        f"--window-size={w},{h}",
        f"--lang={locale[:5]}",
        "--disable-blink-features=AutomationControlled",
        "--disable-sync","--disable-extensions",
        "--disable-background-networking","--disable-default-apps",
        "--disable-translate","--mute-audio","--no-first-run",
        "--disable-features=ChromeWhatsNewUI,TranslateUI",
        "--remote-allow-origins=*",
        f"--ozone-override-screen-size={w},{h}",
        f'--user-agent={ua}',
        f"--user-data-dir={DATA_DIR}",
        "about:blank"
    ]
    if args.proxy_server:
        cmd.insert(4, f"--proxy-server={args.proxy_server}")
    if args.tz:
        cmd.insert(4, f"--timezone={args.tz}")
    if args.profile:
        pdir = os.path.expanduser(f"~/.config/chromium/{args.profile}")
        cmd[cmd.index(f"--user-data-dir={DATA_DIR}")] = f"--user-data-dir={pdir}"
    cmd = [c for c in cmd if c]
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE, start_new_session=True)
    port = None; t0 = time.time()
    while time.time() - t0 < 10:
        line = proc.stderr.readline().decode("utf-8",errors="replace")
        m = re.search(r"ws://[^\s]+:(\d+)",line)
        if m: port = int(m.group(1)); break
    if not port: print("ERROR: cannot find CDP port",file=sys.stderr); proc.kill(); sys.exit(1)
    ws_url = json.loads(urllib.request.urlopen(f"http://127.0.0.1:{port}/json/version").read())["webSocketDebuggerUrl"]
    with open(PID_FILE,"w") as f: json.dump({"pid":proc.pid,"ppid":os.getpid(),"cdp_url":ws_url,"port":port,"w":w,"h":h,"tz":args.tz,"locale":locale},f)
    if args.json: print(json.dumps({"cdp_url":ws_url,"pid":proc.pid,"port":port}))
    else: print(ws_url)
    print(f"[browser-local] PID={proc.pid} port={port} headed={args.headed}",file=sys.stderr); sys.stdout.flush()
    signal.signal(signal.SIGTERM, lambda s,f: sys.exit(0))
    try:
        while True: time.sleep(60)
    except KeyboardInterrupt: os.kill(proc.pid,signal.SIGTERM); proc.wait(); sys.exit(0)

def cmd_with_session(ws, args, ses):
    inject_stealth(ws, ses)
    out = None
    blk = []
    if getattr(args,'block_images',False): blk.extend(["*.jpg","*.jpeg","*.png","*.gif","*.webp","*.svg","*.ico","*.avif","*.bmp","*.tiff","*.webp"])
    if getattr(args,'block_css',False): blk.append("*.css")
    if getattr(args,'block_fonts',False): blk.extend(["*.woff","*.woff2","*.ttf","*.otf","*.eot"])
    if blk or getattr(args,'wait_cf',False):
        if not blk:
            cdp(ws, "Network.enable", session_id=ses)
        else:
            cdp(ws, "Network.enable", session_id=ses)
            cdp(ws, "Network.setBlockedURLs", {"urls": blk}, session_id=ses)
    if args.command == "open":
        cdp(ws, "Page.navigate",{"url":args.url},session_id=ses)
        time.sleep(1.5)
        if getattr(args,'wait_cf',False):
            if _detect_cf_challenge(ws, ses):
                timeout = getattr(args,'cf_timeout',30)
                cleared = _wait_cf_clearance(ws, ses, timeout)
                if cleared:
                    time.sleep(1)
                    cdp(ws, "Page.navigate",{"url":args.url},session_id=ses)
                    for _ in range(20):
                        r = js_eval(ws, ses, "document.readyState")
                        if r == "complete": break
                        time.sleep(0.5)
                else:
                    solve_r = js_eval(ws, ses, TURNSTILE_JS)
                    time.sleep(2)
                    cleared2 = _wait_cf_clearance(ws, ses, timeout//2)
                    if cleared2:
                        time.sleep(1)
                        cdp(ws, "Page.navigate",{"url":args.url},session_id=ses)
                        for _ in range(20):
                            r = js_eval(ws, ses, "document.readyState")
                            if r == "complete": break
                            time.sleep(0.5)
                    else:
                        out = json.dumps({"error":"cf_challenge_timeout","url":args.url,"solve":solve_r})
        if not out:
            out = js_eval(ws, ses, "JSON.stringify({url:location.href,title:document.title,ready:document.readyState})")
    elif args.command == "eval":
        out = js_eval(ws, ses, args.js)
    elif args.command == "screenshot":
        params = {"format":"png","fromSurface":True}
        if getattr(args,'full',False): params["captureBeyondViewport"]=True
        r = cdp(ws, "Page.captureScreenshot",params,session_id=ses)
        data = base64.b64decode(r["data"])
        if args.path:
            with open(args.path,"wb") as f: f.write(data)
            out = json.dumps({"saved":args.path}) if args.json else f"saved {args.path}"
        elif args.json: out = base64.b64encode(data).decode()
        else: out = r["data"]
    elif args.command == "state":
        out = js_eval(ws, ses, "JSON.stringify({url:location.href,title:document.title,ready:document.readyState})")
    elif args.command == "elements":
        out = get_elements(ws, ses)
    elif args.command == "click":
        if len(args.args)==1: out = json.dumps(_click_index(ws,ses,int(args.args[0])))
        elif len(args.args)==2:
            _click_coords(ws,ses,int(args.args[0]),int(args.args[1]))
            out = json.dumps({"clicked":[int(args.args[0]),int(args.args[1])]})
        if getattr(args,'wait_nav',False) and out:
            nav = _wait_navigation(ws, ses)
            out = f"{out}\n{nav}"
        if getattr(args,'wait_idle',False) and out:
            idle = _wait_network_idle(ws, ses)
            out = f"{out}\n{idle}"
    elif args.command == "type":
        out = json.dumps(_type_text(ws,ses,args.text))
    elif args.command == "input":
        out = json.dumps(_type_text(ws,ses,args.text,int(args.index)))
    elif args.command == "scroll":
        out = json.dumps(_scroll(ws,ses,args.direction or "down",args.amount or 300))
    elif args.command == "back":
        js_eval(ws, ses, "history.back()")
        time.sleep(1.5)
        out = js_eval(ws, ses, "JSON.stringify({url:location.href,title:document.title,ready:document.readyState})")
    elif args.command == "tab" and getattr(args,'action',None)=="list":
        r = cdp(ws, "Target.getTargets")
        tabs = [t for t in r.get("targetInfos",[]) if t["type"]=="page"]
        out = json.dumps([{"id":t["targetId"][:8],"title":t["title"][:40],"url":t["url"][:60]} for t in tabs])
    elif args.command == "tab" and getattr(args,'action',None)=="new":
        r = cdp(ws, "Target.createTarget",{"url":"about:blank","newWindow":False})
        out = json.dumps({"targetId":r["targetId"]})
    elif args.command == "keys":
        key_map = {"enter":"Enter","tab":"Tab","escape":"Escape","backspace":"Backspace",
                   "delete":"Delete","arrowup":"ArrowUp","arrowdown":"ArrowDown",
                   "arrowleft":"ArrowLeft","arrowright":"ArrowRight","space":" "}
        k = args.keys
        if k.lower() in key_map: k = key_map[k.lower()]
        modifiers = 0
        if k.startswith("Control+") or k.startswith("Ctrl+"):
            modifiers = 2; k = k.split("+",1)[1]
        cdp(ws, "Input.dispatchKeyEvent",{"type":"keyDown","key":k,"windowsVirtualKeyCode":ord(k[0]) if len(k)==1 else 0,"modifiers":modifiers},session_id=ses)
        cdp(ws, "Input.dispatchKeyEvent",{"type":"keyUp","key":k,"modifiers":modifiers},session_id=ses)
        out = json.dumps({"key":args.keys})
    elif args.command in ("hover","dblclick","rightclick"):
        idx = int(args.index)
        els = json.loads(get_elements(ws, ses))
        if idx < len(els):
            e = els[idx]; x = e["rect"]["x"]+e["rect"]["w"]//2; y = e["rect"]["y"]+e["rect"]["h"]//2
            btn = {"hover":"none","dblclick":"left","rightclick":"right"}[args.command]
            count = {"hover":1,"dblclick":2,"rightclick":1}[args.command]
            if HUMAN_MODE:
                _mouse_move_to(ws, ses, x, y)
            if args.command != "hover":
                if HUMAN_MODE:
                    time.sleep(random.uniform(0.02, 0.08))
                cdp(ws, "Input.dispatchMouseEvent",{"type":"mousePressed","x":x,"y":y,"button":btn,"clickCount":count},session_id=ses)
                if HUMAN_MODE:
                    time.sleep(random.uniform(0.01, 0.04))
                cdp(ws, "Input.dispatchMouseEvent",{"type":"mouseReleased","x":x,"y":y,"button":btn,"clickCount":count},session_id=ses)
            out = json.dumps({args.command:idx,"at":[x,y]})
        else: out = json.dumps({"error":f"index {idx} not found"})
    elif args.command == "select":
        idx = int(args.index)
        els = json.loads(get_elements(ws, ses))
        if idx < len(els):
            e = els[idx]; x = e["rect"]["x"]+e["rect"]["w"]//2; y = e["rect"]["y"]+e["rect"]["h"]//2
            _click_coords(ws,ses,x,y)
            js_eval(ws, ses, f"const el=document.activeElement;if(el&&el.tagName==='SELECT'){{el.value={json.dumps(args.value)};el.dispatchEvent(new Event('change',{{bubbles:true}}))}}")
            out = json.dumps({"selected":args.value})
        else: out = json.dumps({"error":f"index {idx} not found"})
    elif args.command == "upload":
        idx = int(args.index)
        els = json.loads(get_elements(ws, ses))
        if idx < len(els) and os.path.exists(args.path):
            fp = os.path.abspath(args.path)
            cdp(ws, "DOM.setFileInputFiles",{"files":[fp],"nodeId":0},session_id=ses)
            js_eval(ws, ses, f"const el=document.querySelector('input[type=file]');if(el){{const dt=new DataTransfer();const f=new File([''],{json.dumps(os.path.basename(fp))});Object.defineProperty(dt,'files',{{value:[f]}});el.files=dt.files;el.dispatchEvent(new Event('change',{{bubbles:true}}))}}")
            out = json.dumps({"uploaded":fp})
        else: out = json.dumps({"error":"file not found or index out of range"})
    elif args.command == "intercept":
        act = getattr(args,'action',None)
        if act: out = _intercept(ws, ses, act, args)
    elif args.command == "wait":
        wat = getattr(args,'what',None)
        val = getattr(args,'value',None)
        to = getattr(args,'timeout',None) or 15
        if wat == "navigation":
            out = _wait_navigation(ws, ses, to)
        elif wat == "networkidle":
            out = _wait_network_idle(ws, ses, to, getattr(args,'quiet',0.5))
        elif wat == "element":
            out = _wait_element(ws, ses, int(val), to)
        else:
            for _ in range(to * 2):
                if wat == "selector":
                    r = js_eval(ws, ses, f"document.querySelector({json.dumps(val)})!==null")
                elif wat == "text":
                    r = js_eval(ws, ses, f"document.body.innerText.includes({json.dumps(val)})")
                if r: out = json.dumps({"found":val}); break
                time.sleep(0.5)
            if not out: out = json.dumps({"timeout":val})
    elif args.command == "cookies":
        if getattr(args,'action',None) == "get":
            r = cdp(ws,"Network.getAllCookies",session_id=ses)
            out = json.dumps(r.get("cookies",[]),indent=2)
        elif getattr(args,'action',None) == "clear":
            cdp(ws,"Network.clearBrowserCookies",session_id=ses); out = "cookies cleared"
    elif args.command == "solve":
        r = js_eval(ws, ses, TURNSTILE_JS)
        out = r if isinstance(r,str) else json.dumps(r)
        time.sleep(2)
        url = js_eval(ws, ses, "location.href")
        title = js_eval(ws, ses, "document.title")
        out2 = js_eval(ws, ses, "JSON.stringify({url:location.href,title:document.title,ready:document.readyState})")
        out = f"{out}\n{out2}"
    print(out if out else "ok")

def main():
    p = argparse.ArgumentParser(prog="browser-local",description="Chromium CDP automation (browser-use compatible, no cloud)")
    p.add_argument("--cdp-url")
    p.add_argument("--session", default="default")
    p.add_argument("--headed", action="store_true")
    p.add_argument("--json", action="store_true")
    p.add_argument("--human", action="store_true")
    p.add_argument("--block-images", action="store_true")
    p.add_argument("--block-css", action="store_true")
    p.add_argument("--block-fonts", action="store_true")
    sub = p.add_subparsers(dest="command")
    sp = sub.add_parser("start", help="Launch Chromium browser")
    sp.add_argument("--port", type=int, default=0)
    sp.add_argument("--width", type=int, default=0)
    sp.add_argument("--height", type=int, default=0)
    sp.add_argument("--profile")
