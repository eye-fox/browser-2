def cdp(ws, method, params=None, session_id=None):
    if params is None: params = {}
    mid = int(time.time() * 1e6) % 2**31
    msg = {"id": mid, "method": method, "params": params}
    if session_id: msg["sessionId"] = session_id
    ws.send(json.dumps(msg))
    while True:
        raw = ws.recv()
        data = json.loads(raw)
        if data.get("id") == mid:
            if "error" in data: raise Exception(json.dumps(data["error"]))
            return data.get("result")

def js_eval(ws, ses, expr):
    r = cdp(ws, "Runtime.evaluate", {"expression": expr,"returnByValue": True,"awaitPromise": True}, session_id=ses)
    if "exceptionDetails" in r: return {"error": r["exceptionDetails"].get("text",""),"detail": r.get("result",{}).get("description","")}
    return r["result"].get("value")

def get_session(ws, name, stealth_kw=None):
    sessions = {}
    if os.path.exists(SESS_FILE):
        with open(SESS_FILE) as f: sessions = json.load(f)
    if name in sessions:
        tid = sessions[name]["targetId"]
        try:
            ra = cdp(ws, "Target.attachToTarget", {"targetId": tid, "flatten": True})
            sessions[name]["sessionId"] = ra["sessionId"]
            with open(SESS_FILE, "w") as f: json.dump(sessions, f)
            return ra["sessionId"]
        except: del sessions[name]
    r = cdp(ws, "Target.createTarget", {"url": "about:blank", "newWindow": False})
    tid = r["targetId"]
    ra = cdp(ws, "Target.attachToTarget", {"targetId": tid, "flatten": True})
    ses = ra["sessionId"]
    sj = gen_stealth_js(**(stealth_kw or {}))
    cdp(ws, "Page.addScriptToEvaluateOnNewDocument", {"source": sj}, session_id=ses)
    cdp(ws, "Page.enable", session_id=ses)
    if FP.get('tz'):
        try: cdp(ws, "Emulation.setTimezoneOverride", {"timezoneId": FP['tz']}, session_id=ses)
        except: pass
    sessions[name] = {"targetId": tid, "sessionId": ses, "created": time.time()}
    with open(SESS_FILE, "w") as f: json.dump(sessions, f)
    return ses

