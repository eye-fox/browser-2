    sp = sub.add_parser("screenshot", help="Take screenshot")
    sp.add_argument("path", nargs="?")
    sp.add_argument("--full", action="store_true")
    sub.add_parser("state", help="Get browser state")
    sub.add_parser("elements", help="List interactive elements")
    sp = sub.add_parser("click", help="Click element by index or x y")
    sp.add_argument("args", nargs="+")
    sp.add_argument("--wait-nav", action="store_true")
    sp.add_argument("--wait-idle", action="store_true")
    sub.add_parser("type", help="Type into active element").add_argument("text")
    sp = sub.add_parser("input", help="Type into element by index")
    sp.add_argument("index")
    sp.add_argument("text")
    sp = sub.add_parser("scroll", help="Scroll page")
    sp.add_argument("direction", nargs="?", choices=["up","down"], default="down")
