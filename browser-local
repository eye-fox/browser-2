    if args.command == "close":
        if os.path.exists(PID_FILE):
            with open(PID_FILE) as f:
                d = json.load(f)
                ppid = d.get("ppid")
            if ppid:
                try: os.kill(ppid, signal.SIGTERM)
                except: pass
            try:
                for e in os.listdir("/proc"):
                    if e.isdigit():
                        try:
                            with open(f"/proc/{e}/cmdline","rb") as cf:
                                if DATA_DIR.encode() in cf.read():
                                    p = int(e)
                                    if p != os.getpid(): os.kill(p, signal.SIGKILL)
                        except: pass
            except: pass
            time.sleep(2)
        for f in [PID_FILE,SESS_FILE]:
            if os.path.exists(f): os.remove(f)
        if os.path.exists(DATA_DIR):
            for _ in range(15):
                try: shutil.rmtree(DATA_DIR); break
                except: time.sleep(0.5)
        print("closed"); return
    if args.command == "sessions":
        if os.path.exists(SESS_FILE):
            with open(SESS_FILE) as f: s = json.load(f)
            print(json.dumps(s,indent=2) if args.json else json.dumps({k:{"created":time.ctime(v.get("created",0)),"targetId":v["targetId"][:12]+"..."} for k,v in s.items()},indent=2))
        else: print("no sessions"); return
    if args.command == "init": print("# browser-local config"); return
    if args.command == "install":
        if os.path.exists(BROWSER): print(f"Chromium found: {BROWSER}"); sys.exit(0)
        else: print(f"Chromium not found: {BROWSER}"); sys.exit(1)
    if args.command == "doctor":
        deps = {BROWSER: os.path.exists(BROWSER), "python3-websocket": True}
        for d, ok in deps.items(): print(f"{'OK' if ok else 'MISSING'}: {d}")
        sys.exit(0 if all(deps.values()) else 1)
    if args.command == "config": print("config: use env or CLI flags"); return
    if args.command == "connect":
        print("connected"); return

    if not args.cdp_url:
        if os.path.exists(PID_FILE):
            with open(PID_FILE) as f: args.cdp_url = json.load(f)["cdp_url"]
        else:
            print("ERROR: no --cdp-url and no running browser", file=sys.stderr); sys.exit(1)

    ws = create_connection(args.cdp_url, timeout=30)
    try:
        ses = get_session(ws, args.session)
        cmd_with_session(ws, args, ses)
    finally:
        ws.close()

if __name__ == "__main__":
    main()
