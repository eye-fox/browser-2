_last_mouse = {"x": 960, "y": 540}

def _mouse_move_to(ws, ses, tx, ty):
    global _last_mouse
    sx, sy = _last_mouse["x"], _last_mouse["y"]
    dist = ((tx - sx)**2 + (ty - sy)**2)**0.5
    steps = max(3, min(20, int(dist / 15)))
    for i in range(1, steps + 1):
        t = i / steps
        eased = t * (2 - t)
        x = int(sx + (tx - sx) * eased)
        y = int(sy + (ty - sy) * eased)
        cdp(ws, "Input.dispatchMouseEvent", {"type":"mouseMoved","x":x,"y":y}, session_id=ses)
        time.sleep(random.uniform(0.003, 0.012))
    _last_mouse = {"x": tx, "y": ty}

def _click_coords(ws, ses, x, y, btn="left", count=1):
    global HUMAN_MODE
    if HUMAN_MODE:
        _mouse_move_to(ws, ses, x, y)
        time.sleep(random.uniform(0.02, 0.08))
    cdp(ws, "Input.dispatchMouseEvent", {"type":"mousePressed","x":x,"y":y,"button":btn,"clickCount":count}, session_id=ses)
    if HUMAN_MODE:
        time.sleep(random.uniform(0.01, 0.04))
    cdp(ws, "Input.dispatchMouseEvent", {"type":"mouseReleased","x":x,"y":y,"button":btn,"clickCount":count}, session_id=ses)

def _click_index(ws, ses, idx):
    els = json.loads(get_elements(ws, ses))
    if not isinstance(els, list): return {"error":"no elements"}
    if idx >= len(els): return {"error":f"index {idx} out of range (0-{len(els)-1})"}
    e = els[idx]
    x = e["rect"]["x"] + e["rect"]["w"]//2
    y = e["rect"]["y"] + e["rect"]["h"]//2
    _click_coords(ws, ses, x, y)
    return {"clicked":idx,"tag":e["tag"],"text":e["text"][:30],"at":[x,y]}

